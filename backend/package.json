    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.1.3",
    "pg": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.5",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
