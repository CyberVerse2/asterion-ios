{
  "name": "backend",
  "version": "1.0.0",
  "description": "Asterion backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --watch .env --ext ts --exec \"tsx src/server.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "smoke": "node scripts/smoke-test.mjs",
